% pallete.bib
%
% Для каждой записи в комментарии указано, где взять готовый BibTeX «как у издателя».
% Типовые варианты:
%   • DOI: https://doi.org/<DOI> — на странице кнопка «Cite» / «Export» (Crossref, издатель).
%   • IEEE Xplore: страница статьи → «Cite This» → «BibTeX».
%   • SpringerLink / Nature: «Cite this article» → BibTeX.
%   • ScienceDirect: «Export» → BibTeX.
%   • INFORMS: страница статьи → Download citations / cite.
%   • arXiv: страница абстракта → «Export BibTeX Citation».
%   • dblp: https://dblp.org — страница публикации → «export record» → BibTeX.
%   • Google Patents: страница патента → «Cite» (проверьте поля вручную).
%   • Google Scholar: «Цитировать» → BibTeX (поля часто кривые — сверяйте с DOI).
%
% Записи ниже могут отличаться от автоэкспорта (сокращения, поля для gost780u) —
% комментарий указывает канонический URL для сверки.

% --- TR-MFTI-khelvas2019-boxes ---
% Поиск и экспорт: elibrary.ru по названию / авторам; либо сайт выпуска трудов МФТИ.
%   https://www.elibrary.ru/  (поиск: «Разработка алгоритма укладки паллет» Хельвас)
@ARTICLE{TR-MFTI-khelvas2019-boxes,
  author = {Гиля - Зетинов,А.А. and Хельвас, А.В. and     Панкратов, К.К.},
  title = {Разработка алгоритма укладки паллет на полностью автоматизированном складе},
  journal = {Труды Московского физико-технического института},
  year = {2019},
  volume = {11},
  number = {1(41)},
  pages = {20-30},
  language = {russian},
  annotation={Решается задача трехмерной укладки коробок в паллету, относящаяся к классу NP-полных задач. Предложено несколько эвристических подходов к ее решению: на основе эвристик слоев и на основе генетического алгоритма. Предложен подход к оценке качества укладки на основе коэффициента перколяции и коэффициента устойчивости.
Показана слабая зависимость качества укладки от точности задания размеров коробок.}
}

